<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.AccountSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="640" HorizontalAlignment="Center" Padding="24,20,24,32" Spacing="4">

            <!-- ── Page header ────────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,16">
                <Border Width="40" Height="40" CornerRadius="8"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xE713;" FontSize="20"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="Settings"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock Text="Appearance, profile, privacy and security"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" IsClosable="True" Margin="0,0,0,4" />
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                         Margin="0,0,0,4" />

            <!-- ── Appearance ────────────────────────────────────────────── -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE790;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Appearance"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="16" Padding="0,8,0,8">

                    <!-- Theme -->
                    <ComboBox x:Name="ThemeCombo" Header="App theme"
                              HorizontalAlignment="Stretch"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="Use system setting" Tag="default" />
                        <ComboBoxItem Content="Light" Tag="light" />
                        <ComboBoxItem Content="Dark" Tag="dark" />
                    </ComboBox>

                    <!-- Accent color -->
                    <StackPanel Spacing="8">
                        <TextBlock Text="Accent color"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel x:Name="AccentSwatchesPanel"
                                    Orientation="Horizontal" Spacing="10" />
                    </StackPanel>

                    <InfoBar x:Name="AccentRestartBar" IsOpen="False" IsClosable="True"
                             Severity="Informational"
                             Message="Accent color updated. Some elements may need a page change to refresh." />

                </StackPanel>
            </Expander>

            <!-- ── Profile ──────────────────────────────────────────────── -->
            <Expander IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE77B;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Profile"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,8,0,8">

                    <TextBox x:Name="DisplayNameBox" Header="Display name"
                             PlaceholderText="Your display name" MaxLength="50" />
                    <!-- Rendered preview of the display name including remote emoji images -->
                    <StackPanel x:Name="DisplayNamePreview"
                                Orientation="Horizontal"
                                Visibility="Collapsed" />
                    <TextBox x:Name="DescriptionBox" Header="Bio"
                             PlaceholderText="About yourself…"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="80" MaxLength="1500" />
                    <TextBox x:Name="LocationBox" Header="Location"
                             PlaceholderText="e.g. Tokyo, Japan" MaxLength="50" />
                    <DatePicker x:Name="BirthdayPicker" Header="Birthday" />
                    <ComboBox x:Name="LangBox" Header="Language (interface hint)"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="(not set)" Tag="" IsSelected="True" />
                        <ComboBoxItem Content="English" Tag="en-US" />
                        <ComboBoxItem Content="日本語" Tag="ja-JP" />
                        <ComboBoxItem Content="Deutsch" Tag="de-DE" />
                        <ComboBoxItem Content="Français" Tag="fr-FR" />
                        <ComboBoxItem Content="Español" Tag="es-ES" />
                        <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                        <ComboBoxItem Content="繁體中文" Tag="zh-TW" />
                        <ComboBoxItem Content="한국어" Tag="ko-KR" />
                        <ComboBoxItem Content="Русский" Tag="ru-RU" />
                    </ComboBox>

                    <Button Content="Save profile" Style="{StaticResource AccentButtonStyle}"
                            Click="SaveProfileButton_Click" />
                </StackPanel>
            </Expander>

            <!-- ── Privacy ──────────────────────────────────────────────── -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE72E;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Privacy"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,8,0,8">

                    <!-- Toggle rows as Windows-Settings-style cards -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <StackPanel>

                            <!-- Lock account -->
                            <Grid Padding="16,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Lock account" />
                                    <TextBlock Text="New followers need your approval before they can follow you"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="IsLockedSwitch" Grid.Column="1"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Rectangle Height="1" HorizontalAlignment="Stretch"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <!-- Appear in Explore -->
                            <Grid Padding="16,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Appear in Explore" />
                                    <TextBlock Text="Allow your profile and notes to show in Explore and trending"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="IsExplorableSwitch" Grid.Column="1"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Rectangle Height="1" HorizontalAlignment="Stretch"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <!-- Hide online status -->
                            <Grid Padding="16,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Hide online status" />
                                    <TextBlock Text="Don't show when you were last active to other users"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="HideOnlineStatusSwitch" Grid.Column="1"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Rectangle Height="1" HorizontalAlignment="Stretch"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <!-- Public reactions -->
                            <Grid Padding="16,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Public reactions" />
                                    <TextBlock Text="Let others see which notes you have reacted to"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="PublicReactionsSwitch" Grid.Column="1"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Rectangle Height="1" HorizontalAlignment="Stretch"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <!-- Prevent AI training -->
                            <Grid Padding="16,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Prevent AI training" />
                                    <TextBlock Text="Request that your content is not used to train AI models"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="PreventAiSwitch" Grid.Column="1"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center" Margin="0" />
                            </Grid>

                            <Rectangle Height="1" HorizontalAlignment="Stretch"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

                            <!-- Block search engine indexing -->
                            <Grid Padding="16,12" ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="Block search engine indexing" />
                                    <TextBlock Text="Add noindex hints to your public pages"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch x:Name="NoCrawleSwitch" Grid.Column="1"
                                             OffContent="" OnContent=""
                                             VerticalAlignment="Center" Margin="0" />
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- Visibility dropdowns -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="FollowingVisBox" Header="Following list visibility"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Public" Tag="public" IsSelected="True" />
                            <ComboBoxItem Content="Followers only" Tag="followers" />
                            <ComboBoxItem Content="Private" Tag="private" />
                        </ComboBox>
                        <ComboBox x:Name="FollowersVisBox" Grid.Column="1"
                                  Header="Followers list visibility"
                                  HorizontalAlignment="Stretch">
                            <ComboBoxItem Content="Public" Tag="public" IsSelected="True" />
                            <ComboBoxItem Content="Followers only" Tag="followers" />
                            <ComboBoxItem Content="Private" Tag="private" />
                        </ComboBox>
                    </Grid>

                    <Button Content="Save privacy settings"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SavePrivacyButton_Click" />
                </StackPanel>
            </Expander>

            <!-- ── Muted words ───────────────────────────────────────────── -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE74F;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Muted Words"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="8" Padding="0,8,0,8">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}">
                        One entry per line. Separate words with spaces to mute notes containing
                        ALL of those words; a single word mutes any note containing it.
                    </TextBlock>
                    <TextBox x:Name="MutedWordsBox"
                             Header="Muted words"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="100"
                             PlaceholderText="word1&#x0a;bad phrase here&#x0a;another term" />
                    <TextBox x:Name="MutedInstancesBox"
                             Header="Muted instances (one hostname per line)"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="60"
                             PlaceholderText="spam.example.com" />
                    <Button Content="Save muted words"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SaveMutedWordsButton_Click" />
                </StackPanel>
            </Expander>

            <!-- ── Security ──────────────────────────────────────────────── -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE8A2;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Security"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,8,0,8">

                    <!-- Change password card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE965;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Change password"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <PasswordBox x:Name="CurrentPasswordBox"
                                         Header="Current password"
                                         PlaceholderText="Enter current password" />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <PasswordBox x:Name="NewPasswordBox"
                                             Header="New password"
                                             PlaceholderText="At least 8 characters" />
                                <PasswordBox x:Name="ConfirmPasswordBox" Grid.Column="1"
                                             Header="Confirm new password"
                                             PlaceholderText="Repeat new password" />
                            </Grid>
                            <TextBox x:Name="PasswordTwoFactorBox"
                                     Header="2FA token (if enabled)"
                                     PlaceholderText="6-digit code" />
                            <Button Content="Change password"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="ChangePasswordButton_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Change email card -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="16,14">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE715;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Change email address"
                                           Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBox x:Name="NewEmailBox"
                                     Header="New email address"
                                     PlaceholderText="you@example.com"
                                     InputScope="EmailSmtpAddress" />
                            <PasswordBox x:Name="EmailPasswordBox"
                                         Header="Current password (required to change email)"
                                         PlaceholderText="Enter current password" />
                            <Button Content="Update email"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="ChangeEmailButton_Click" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Expander>

            <!-- ── Notification settings nav card ─────────────────────────── -->
            <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                    Padding="16,14" Margin="0,4,0,0"
                    Click="OpenNotifSettingsButton_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xEA8F;" FontSize="18" VerticalAlignment="Center"
                              Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                    <StackPanel Grid.Column="1" Margin="14,0,0,0" Spacing="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="Notification Settings"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Configure who can send each notification type and email alerts"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12"
                              VerticalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Button>

            <!-- ── Windows Hello ─────────────────────────────────────────── -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xEE57;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Windows Hello"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="12" Padding="0,8,0,8">

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}">
                        When enabled, Windows will ask for your fingerprint, face, or PIN
                        each time you open the app. Your API token is always stored encrypted
                        in the Windows Credential Manager.
                    </TextBlock>

                    <InfoBar x:Name="HelloStatusBar" IsOpen="False" IsClosable="False"
                             IsIconVisible="True" />

                    <!-- Hello toggle row -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="8">
                        <Grid Padding="16,12" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Require Windows Hello on startup" />
                                <TextBlock Text="Biometric or PIN check each time the app is launched"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ToggleSwitch x:Name="HelloSwitch" Grid.Column="1"
                                         OffContent="" OnContent=""
                                         VerticalAlignment="Center" Margin="0"
                                         Toggled="HelloSwitch_Toggled" />
                        </Grid>
                    </Border>

                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
