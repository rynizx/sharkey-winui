<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.WindowsHelloLockPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
        <StackPanel Spacing="20" Padding="32">

            <!-- App icon -->
            <FontIcon Glyph="&#xE909;" FontSize="56"
                      HorizontalAlignment="Center"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />

            <!-- App name -->
            <TextBlock Text="Sharkey WinUI"
                       Style="{StaticResource TitleTextBlockStyle}"
                       HorizontalAlignment="Center" />

            <!-- Account pill -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="20" Padding="12,8" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <!-- Avatar -->
                    <Ellipse Width="32" Height="32">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="AccountNameText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   MaxWidth="200"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock x:Name="ServerText"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Windows Hello button -->
            <Button x:Name="HelloButton"
                    HorizontalAlignment="Stretch"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="HelloButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <!-- Fingerprint / Hello icon -->
                    <FontIcon Glyph="&#xECF3;" FontSize="20" />
                    <TextBlock x:Name="HelloButtonText" Text="Sign in with Windows Hello"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Progress ring shown while verifying -->
            <ProgressRing x:Name="Spinner" IsActive="False"
                          HorizontalAlignment="Center" Width="28" Height="28" />

            <!-- Error / info bar -->
            <InfoBar x:Name="StatusBar"
                     IsOpen="False"
                     IsClosable="True" />

            <!-- Fallback links -->
            <StackPanel HorizontalAlignment="Center" Spacing="4">
                <HyperlinkButton x:Name="UseTokenButton"
                                 Content="Sign in with a different account or token"
                                 Click="UseTokenButton_Click" />
                <HyperlinkButton x:Name="SignOutButton"
                                 Content="Sign out and clear saved credentials"
                                 Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                 Click="SignOutButton_Click" />
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
