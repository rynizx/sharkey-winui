<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.NoteDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SharkeyWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="8,0">
        <StackPanel MaxWidth="680" HorizontalAlignment="Center">

            <!-- Loading / error -->
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed" />
            <InfoBar x:Name="ErrorBar" IsOpen="False" IsClosable="True" Severity="Error" />

            <!-- Original post context (visible when the root note is a reply) -->
            <StackPanel x:Name="ParentNoteSection" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="16,8,0,2">
                    <FontIcon Glyph="&#xE97A;" FontSize="11"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="Original post"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <controls:NoteCard x:Name="ParentNoteCard" />
                <!-- Thread connector line between parent and reply -->
                <Grid Height="20" Margin="36,0,0,0" HorizontalAlignment="Left" Width="2">
                    <Rectangle Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                               HorizontalAlignment="Stretch" />
                </Grid>
            </StackPanel>

            <!-- Root note -->
            <controls:NoteCard x:Name="RootNoteCard" />

            <!-- Replies header -->
            <TextBlock Text="Replies"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Margin="12,14,12,6" />

            <!-- Replies list -->
            <ListView x:Name="RepliesList" Margin="8,0,0,0"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="RepliesList_ItemClick">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel ItemsUpdatingScrollMode="KeepScrollOffset" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:NoteCard Note="{Binding}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Load more replies -->
            <Button x:Name="LoadMoreRepliesButton"
                    Content="Load more replies"
                    AutomationProperties.Name="Load more replies"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,20"
                    Visibility="Collapsed"
                    Click="LoadMoreRepliesButton_Click" />

        </StackPanel>
    </ScrollViewer>
</Page>
