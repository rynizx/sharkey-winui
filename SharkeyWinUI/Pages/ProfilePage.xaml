<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SharkeyWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel>

            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed" />
            <InfoBar x:Name="ErrorBar" IsOpen="False" IsClosable="True" Severity="Error" />

            <!-- Banner -->
            <Grid Height="180">
                <Image x:Name="BannerImage" Stretch="UniformToFill" />
                <Rectangle Fill="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" Opacity="0.35" />
            </Grid>

            <!-- Avatar + actions row -->
            <Grid Padding="20,-36,20,0" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Avatar with ring -->
                <Border CornerRadius="42" BorderBrush="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderThickness="3" Width="84" Height="84" VerticalAlignment="Bottom">
                    <Ellipse Width="78" Height="78">
                        <Ellipse.Fill>
                            <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="2">
                    <TextBlock x:Name="DisplayNameText"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="UsernameText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Follow / Unfollow / Pending -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Bottom">
                    <Button x:Name="FollowButton"
                            Content="Follow"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="FollowButton_Click"
                            Visibility="Collapsed" />
                    <Button x:Name="UnfollowButton"
                            Content="Unfollow"
                            Click="UnfollowButton_Click"
                            Visibility="Collapsed" />
                    <Button x:Name="PendingButton"
                            Content="Requested"
                            IsEnabled="False"
                            Visibility="Collapsed" />
                    <Button x:Name="BlockButton"
                            Content="Blocked"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Visibility="Collapsed"
                            Click="BlockButton_Click" />
                </StackPanel>
            </Grid>

            <!-- Bio + meta -->
            <StackPanel Padding="20,14" Spacing="10">
                <TextBlock x:Name="BioText" TextWrapping="Wrap" LineHeight="22" />

                <StackPanel x:Name="RolesPanel" Orientation="Horizontal"
                            Spacing="6" Visibility="Collapsed" />

                <!-- Fields -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8" Padding="12,8"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <ItemsControl x:Name="FieldsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                               TextWrapping="Wrap" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Stats row -->
                <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,4,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="NotesCountText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Notes"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="FollowingCountText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Following"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="FollowersCountText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Followers"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Federated instance info -->
                <TextBlock x:Name="InstanceText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed" />

            </StackPanel>

            <!-- Notes tab -->
            <Rectangle Height="1" HorizontalAlignment="Stretch"
                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                       Margin="20,4,20,0" />
            <TextBlock Text="Notes" Padding="20,12,20,8"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />

            <ListView x:Name="NotesList" Margin="8,0"
                      SelectionMode="None"
                      IsItemClickEnabled="True"
                      ItemClick="NotesList_ItemClick">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <controls:NoteCard Note="{Binding}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button x:Name="LoadMoreNotesButton"
                    Content="Load more notes"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,20"
                    Visibility="Collapsed"
                    Click="LoadMoreNotesButton_Click" />

        </StackPanel>
    </ScrollViewer>
</Page>
