<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SharkeyWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Search"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Padding="16,12" />

        <!-- Search bar -->
        <Grid Grid.Row="1" Padding="16,0,16,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="Search notes or @users…"
                            QueryIcon="Find"
                            QuerySubmitted="SearchBox_QuerySubmitted"
                            KeyDown="SearchBox_KeyDown" />
            <!-- Search type toggle -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                <ToggleButton x:Name="NotesToggle"
                              Content="Notes"
                              IsChecked="True"
                              Click="SearchTypeToggle_Click"
                              Tag="notes" />
                <ToggleButton x:Name="UsersToggle"
                              Content="Users"
                              IsChecked="False"
                              Click="SearchTypeToggle_Click"
                              Tag="users" />
            </StackPanel>
        </Grid>

        <!-- Error bar -->
        <InfoBar x:Name="ErrorBar" Grid.Row="2"
                 IsOpen="False" IsClosable="True" Severity="Error" />

        <!-- Notes results -->
        <ListView x:Name="NotesList"
                  Grid.Row="3"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="NotesList_ItemClick"
                  Visibility="Visible">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <controls:NoteCard Note="{Binding}"
                                       BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                       BorderThickness="0,0,0,1" />
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Footer>
                <Button x:Name="LoadMoreNotesButton"
                        Content="Load more"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,16"
                        Visibility="Collapsed"
                        Click="LoadMoreNotesButton_Click" />
            </ListView.Footer>
        </ListView>

        <!-- User results -->
        <ListView x:Name="UsersList"
                  Grid.Row="3"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="UsersList_ItemClick"
                  Visibility="Collapsed">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,8" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Ellipse Width="40" Height="40">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding AvatarUrl}"
                                            Stretch="UniformToFill" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding EffectiveName}"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="{Binding FullUsername}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Footer>
                <Button x:Name="LoadMoreUsersButton"
                        Content="Load more"
                        HorizontalAlignment="Center"
                        Margin="0,8,0,16"
                        Visibility="Collapsed"
                        Click="LoadMoreUsersButton_Click" />
            </ListView.Footer>
        </ListView>

        <!-- Loading indicator -->
        <ProgressBar x:Name="LoadingBar" Grid.Row="4"
                     IsIndeterminate="True" Visibility="Collapsed" />
    </Grid>
</Page>
