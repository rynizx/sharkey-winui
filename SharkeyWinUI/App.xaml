<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="SharkeyWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── System accent color overrides ──────────────────────── -->
            <!-- Ensures every WinUI control (NavView indicator, ToggleSwitch,
                 CheckBox, ProgressBar, Slider, etc.) uses the app accent
                 instead of the OS-level Windows accent color. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- Light theme: accent controls use a darker shade for contrast on light backgrounds.
                         Color (SystemAccentColor*) resources are set at runtime by ThemeService. -->
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#E03870" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E0E03870" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#C0E03870" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <!-- Dark theme: accent controls use a lighter shade for contrast on dark backgrounds.
                         Color (SystemAccentColor*) resources are set at runtime by ThemeService. -->
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#FF8BB5" />
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E0FF6BA0" />
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#C0FF6BA0" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- App accent color resources -->
            <SolidColorBrush x:Key="AppAccentBrush"                        Color="#FF4081"/>
            <SolidColorBrush x:Key="AppSecondaryBrush"                     Color="#7C4DFF"/>

            <!-- AccentButton overrides — all accent-styled buttons use the app accent -->
            <SolidColorBrush x:Key="AccentButtonBackground"              Color="#FF4081" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver"   Color="#E03870" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed"       Color="#CC305F" />
            <SolidColorBrush x:Key="AccentButtonBackgroundDisabled"      Color="#884060" />

            <!-- Shared layout tokens -->
            <Thickness x:Key="AppPageHeaderPadding">20,14</Thickness>
            <Thickness x:Key="AppPageContentPadding">16</Thickness>
            <Thickness x:Key="AppPageWideContentPadding">24,20,24,32</Thickness>

            <!-- Shared styles -->
            <Style x:Key="AppPageHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource SubtitleTextBlockStyle}" />

            <Style x:Key="AppCardContainerStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="AppCenteredFeedListStyle" TargetType="ListView">
                <Setter Property="MaxWidth" Value="680" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Padding" Value="8,0" />
            </Style>

            <Style x:Key="AppStretchListItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,2" />
            </Style>

            <Style x:Key="AppLoadMoreButtonStyle" TargetType="Button">
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,12,0,20" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
