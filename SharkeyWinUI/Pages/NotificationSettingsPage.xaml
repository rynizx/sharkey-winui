<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.NotificationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel MaxWidth="680" HorizontalAlignment="Center" Padding="{StaticResource AppPageWideContentPadding}" Spacing="4">

            <!-- ── Page header ────────────────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="14" Margin="0,0,0,16">
                <Border Width="40" Height="40" CornerRadius="8"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <FontIcon Glyph="&#xEA8F;" FontSize="20"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center" Spacing="1">
                    <TextBlock Text="Notification Settings"
                               Style="{StaticResource AppPageHeaderTextStyle}" />
                    <TextBlock Text="Control which notifications you receive and how"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </StackPanel>

            <InfoBar x:Name="StatusBar" IsOpen="False" IsClosable="True" Margin="0,0,0,4" />
            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed"
                         Margin="0,0,0,4" />

            <!-- ── Per-type receive config ──────────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,4">
                <FontIcon Glyph="&#xE8A2;" FontSize="14" VerticalAlignment="Center"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="Who can send each notification type"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}">
                Control which users can trigger each type of notification.
                "Everyone" means all users; "Never" disables the type entirely.
            </TextBlock>

            <!-- One card row per notification type -->
            <Border Style="{StaticResource AppCardContainerStyle}">
                <ItemsControl x:Name="ReceiveConfigList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Grid Padding="14,10" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="170" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center"
                                               Style="{StaticResource BodyTextBlockStyle}" />
                                    <ComboBox Grid.Column="1"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              ItemsSource="{Binding Options}"
                                              SelectedItem="{Binding SelectedOption, Mode=TwoWay}" />
                                </Grid>
                                <!-- A divider is included in every DataTemplate row.
                                     The outer Border's CornerRadius clips the final one. -->
                                <Rectangle Height="1" HorizontalAlignment="Stretch"
                                           Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- ── Email notification types ───────────────────────────────── -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,20,0,4">
                <FontIcon Glyph="&#xE715;" FontSize="14" VerticalAlignment="Center"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="Email notifications"
                           Style="{StaticResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}">
                Choose which events send you an email. Requires a verified email address on the server.
            </TextBlock>

            <Border Style="{StaticResource AppCardContainerStyle}" Padding="16,10">
                <StackPanel x:Name="EmailTypesPanel" Spacing="6" />
            </Border>

            <!-- ── Save ───────────────────────────────────────────────────── -->
            <Button x:Name="SaveButton"
                    Content="Save notification settings"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    Click="SaveButton_Click" />

        </StackPanel>
    </ScrollViewer>
</Page>
