<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SharkeyWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="{StaticResource AppPageHeaderPadding}" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HeaderText"
                       Style="{StaticResource AppPageHeaderTextStyle}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    x:Name="RefreshButton"
                    ToolTipService.ToolTip="Refresh"
                    AutomationProperties.Name="Refresh"
                    Click="RefreshButton_Click">
                <FontIcon Glyph="&#xE72C;" FontSize="16" />
            </Button>
        </Grid>

        <!-- Error bar -->
        <InfoBar x:Name="ErrorBar" Grid.Row="1" IsOpen="False" IsClosable="True"
                 Severity="Error" />

        <!-- Loading indicator — sits at the top of the list area as a thin overlay -->
        <ProgressBar x:Name="LoadingBar" Grid.Row="2"
                     IsIndeterminate="True"
                     VerticalAlignment="Top"
                     Visibility="Collapsed" />

        <!-- Empty state — shown when timeline loaded successfully but is empty -->
        <StackPanel x:Name="EmptyState"
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xE7C3;" FontSize="48"
                      AutomationProperties.Name="No notes icon"
                      Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                      HorizontalAlignment="Center" />
            <TextBlock Text="Nothing here yet"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Refresh to check for new notes."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Notes list -->
        <ListView x:Name="NotesList"
              Grid.Row="2"
              Style="{StaticResource AppCenteredFeedListStyle}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="NotesList_ItemClick">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel ItemsUpdatingScrollMode="KeepScrollOffset" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <StaticResource ResourceKey="AppStretchListItemStyle" />
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <controls:NoteCard Note="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Footer>
                <Button x:Name="LoadMoreButton"
                        Content="Load more"
                        Style="{StaticResource AppLoadMoreButtonStyle}"
                    AutomationProperties.Name="Load more notes"
                        Visibility="Collapsed"
                        Click="LoadMoreButton_Click" />
            </ListView.Footer>
        </ListView>

    </Grid>
</Page>
