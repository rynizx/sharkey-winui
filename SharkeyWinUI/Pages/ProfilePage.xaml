<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SharkeyWinUI.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SharkeyWinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel>

            <ProgressBar x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed" />
            <InfoBar x:Name="ErrorBar" IsOpen="False" IsClosable="True" Severity="Error" />

            <!-- Banner -->
            <Grid Height="160">
                <Image x:Name="BannerImage" Stretch="UniformToFill" />
                <Rectangle Fill="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}" Opacity="0.3" />
            </Grid>

            <!-- Avatar + actions row -->
            <Grid Padding="16,-32,16,0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Ellipse Width="72" Height="72" VerticalAlignment="Bottom">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill" />
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="2">
                    <TextBlock x:Name="DisplayNameText"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="UsernameText"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <!-- Follow / Unfollow / Pending -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Bottom">
                    <Button x:Name="FollowButton"
                            Content="Follow"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="FollowButton_Click"
                            Visibility="Collapsed" />
                    <Button x:Name="UnfollowButton"
                            Content="Unfollow"
                            Click="UnfollowButton_Click"
                            Visibility="Collapsed" />
                    <Button x:Name="PendingButton"
                            Content="Requested"
                            IsEnabled="False"
                            Visibility="Collapsed" />
                    <Button x:Name="BlockButton"
                            Content="Blocked"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Visibility="Collapsed"
                            Click="BlockButton_Click" />
                </StackPanel>
            </Grid>

            <!-- Bio + meta -->
            <StackPanel Padding="16,12" Spacing="8">
                <TextBlock x:Name="BioText" TextWrapping="Wrap" />

                <StackPanel x:Name="RolesPanel" Orientation="Horizontal"
                            Spacing="4" Visibility="Collapsed" />

                <!-- Fields -->
                <ItemsControl x:Name="FieldsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Value}"
                                           TextWrapping="Wrap" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Stats row -->
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <StackPanel>
                        <TextBlock x:Name="NotesCountText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Notes"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock x:Name="FollowingCountText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Following"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock x:Name="FollowersCountText"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="Followers"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Federated instance info -->
                <TextBlock x:Name="InstanceText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed" />

            </StackPanel>

            <!-- Notes tab -->
            <TextBlock Text="Notes" Padding="16,0,16,8"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />

            <ItemsControl x:Name="NotesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:NoteCard Note="{Binding}"
                                           BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                           BorderThickness="0,0,0,1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="LoadMoreNotesButton"
                    Content="Load more notes"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,16"
                    Visibility="Collapsed"
                    Click="LoadMoreNotesButton_Click" />

        </StackPanel>
    </ScrollViewer>
</Page>
